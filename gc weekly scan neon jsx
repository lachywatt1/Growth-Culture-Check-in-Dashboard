function MacroBar({ label, actual, target, unit }) {
  const pct = Math.min((actual / target) * 100, 100);
  const over = actual > target * 1.08, under = actual < target * 0.92;
  const color = over ? OFF : under ? WATCH : GOOD;
  return (
    <div style={{ marginBottom: 11 }}>
      <div style={{ display: "flex", justifyContent: "space-between", fontSize: 11.5, marginBottom: 5, fontFamily: mono }}>
        <span style={{ color: TEXT }}>{label}</span>
        <span style={{ color: DIM }}>{actual}<span style={{ color: FAINT }}> / {target} {unit}</span></span>
      </div>
      <div style={{ height: 4, background: "rgba(255,255,255,0.06)", borderRadius: 100, overflow: "hidden" }}>
        <div style={{ width: `${pct}%`, height: "100%",
          background: `linear-gradient(90deg,${color},${CYAN})`, borderRadius: 100,
          boxShadow: `0 0 12px ${color}`, animation: "barFill 1s ease both" }} />
      </div>
    </div>
  );
}

