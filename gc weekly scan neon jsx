function Particles() {
  const dots = Array.from({ length: 18 });
  return (
    <div style={{ position: "absolute", inset: 0, overflow: "hidden", pointerEvents: "none" }}>
      {dots.map((_, i) => {
        const left = (i * 53) % 100;
        const dur = 14 + (i % 7) * 3;
        const delay = (i % 9) * 1.6;
        const c = i % 2 ? BLUE : CYAN;
        return <div key={i} className="particle" style={{ left: `${left}%`,
          background: c, boxShadow: `0 0 6px ${c}`,
          animation: `floatUp ${dur}s linear ${delay}s infinite` }} />;
      })}
    </div>
  );
}

function Starfield() {
  // deterministic pseudo-random scatter of twinkling stars
  const stars = Array.from({ length: 70 }).map((_, i) => {
    const x = (i * 97 + 13) % 100;
    const y = (i * 53 + 7) % 100;
    const size = ((i * 7) % 3) * 0.6 + 0.7;
    const dur = 2 + ((i * 3) % 5);
    const delay = (i % 11) * 0.4;
    const bright = (i % 4) === 0;
    return { x, y, size, dur, delay, bright };
  });
  return (
    <div style={{ position: "absolute", inset: 0, overflow: "hidden", pointerEvents: "none" }}>
      {stars.map((s, i) => (
        <div key={i} style={{ position: "absolute", left: `${s.x}%`, top: `${s.y}%`,
          width: s.size, height: s.size, borderRadius: "50%",
          background: s.bright ? CYAN : "#cfe3ff",
          boxShadow: s.bright ? `0 0 6px ${CYAN}` : `0 0 3px rgba(207,227,255,0.7)`,
          animation: `twinkle ${s.dur}s ease-in-out ${s.delay}s infinite` }} />
      ))}
    </div>
  );
}

function Pill({ children, tone, pulse }) {
  const map = {
    good: { fg: GOOD, bd: "rgba(94,233,176,0.4)", bg: "rgba(94,233,176,0.1)" },
    watch: { fg: WATCH, bd: "rgba(255,212,122,0.4)", bg: "rgba(255,212,122,0.1)" },
    off: { fg: OFF, bd: "rgba(255,138,122,0.4)", bg: "rgba(255,138,122,0.1)" },
    blue: { fg: BLUE, bd: "rgba(77,184,255,0.4)", bg: "rgba(77,184,255,0.1)" },
    neutral: { fg: DIM, bd: BORDER, bg: PANEL },
  };
  const c = map[tone] || map.neutral;
  return (
    <span style={{ color: c.fg, border: `1px solid ${c.bd}`, background: c.bg, fontSize: 10.5,
      fontWeight: 600, padding: "3px 9px", borderRadius: 100, whiteSpace: "nowrap", fontFamily: mono,
      letterSpacing: "0.02em", animation: pulse ? "pulseGlow 2s ease-in-out infinite" : "none", "--c": c.bd }}>{children}</span>
  );
}

