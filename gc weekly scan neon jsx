    <div style={{ marginBottom: 26 }}>
      <SectionLabel>Body metrics</SectionLabel>

      {/* Row 1: Weight + Sleep */}
      <div style={{ display: "flex", gap: 14, flexWrap: "wrap", marginBottom: 14 }}>

        {/* Weight */}
        <div style={{ flex: 1, minWidth: 200, background: "rgba(255,255,255,0.02)",
          border: `1px solid ${BORDER}`, borderRadius: 10, padding: "12px 14px" }}>
          <div style={{ fontSize: 10, letterSpacing: "0.12em", textTransform: "uppercase",
            color: CYAN, fontWeight: 700, fontFamily: mono, marginBottom: 10 }}>Weight</div>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: 8 }}>
            <div>
              <div style={{ fontSize: 9.5, color: FAINT, fontFamily: mono, marginBottom: 2 }}>CURRENT</div>
              <div style={{ fontFamily: "Archivo, sans-serif", fontSize: 26, fontWeight: 700, color: TEXT }}>{bm.weight.current}<span style={{ fontSize: 13, color: DIM }}> kg</span></div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div style={{ fontSize: 9.5, color: FAINT, fontFamily: mono, marginBottom: 2 }}>WK AVG</div>
              <div style={{ fontFamily: "Archivo, sans-serif", fontSize: 26, fontWeight: 700, color: DIM }}>{bm.weight.weekAvg}<span style={{ fontSize: 13, color: FAINT }}> kg</span></div>
            </div>
          </div>
          <div style={{ fontSize: 11, color: DIM, marginBottom: 4 }}>
            Prev wk avg: <span style={{ color: TEXT }}>{bm.weight.prevWeekAvg}kg</span>
            {" · "}Δ <span style={{ color: bm.weight.weekAvg <= bm.weight.prevWeekAvg ? GOOD : OFF }}>
              {bm.weight.weekAvg <= bm.weight.prevWeekAvg ? "" : "+"}{(bm.weight.weekAvg - bm.weight.prevWeekAvg).toFixed(1)}kg
            </span>
          </div>
          <div style={{ fontSize: 10.5, color: FAINT, fontFamily: mono }}>Started {bm.weight.starting}kg · {bm.weight.trend}</div>
        </div>

        {/* Sleep */}
        <div style={{ flex: 1, minWidth: 220, background: "rgba(255,255,255,0.02)",
          border: `1px solid ${BORDER}`, borderRadius: 10, padding: "12px 14px" }}>
          <div style={{ fontSize: 10, letterSpacing: "0.12em", textTransform: "uppercase",
            color: CYAN, fontWeight: 700, fontFamily: mono, marginBottom: 10 }}>Sleep</div>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: 8 }}>
            <div>
              <div style={{ fontSize: 9.5, color: FAINT, fontFamily: mono, marginBottom: 2 }}>CURRENT (last night)</div>
              <div style={{ fontFamily: "Archivo, sans-serif", fontSize: 22, fontWeight: 700, color: TEXT }}>{bm.sleep.daily[0]?.duration}</div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div style={{ fontSize: 9.5, color: FAINT, fontFamily: mono, marginBottom: 2 }}>WK AVG</div>
              <div style={{ fontFamily: "Archivo, sans-serif", fontSize: 22, fontWeight: 700, color: DIM }}>{sleepAvgStr}</div>
            </div>
          </div>
          <div style={{ fontSize: 11, color: DIM, marginBottom: 8 }}>Bed avg: <span style={{ color: TEXT, fontFamily: mono }}>{bm.sleep.bedTime}</span></div>
          <div style={{ display: "flex", flexDirection: "column", gap: 2 }}>
            {bm.sleep.daily.map(d => (
              <div key={d.date} style={{ display: "flex", justifyContent: "space-between", fontSize: 10.5, fontFamily: mono }}>
                <span style={{ color: FAINT }}>{d.date}</span>
                <span style={{ color: parseInt(d.duration) >= 8 ? GOOD : WATCH }}>{d.duration}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Row 2: Steps + vitals */}
      <div style={{ display: "flex", gap: 14, flexWrap: "wrap" }}>

        {/* Steps */}
        <div style={{ flex: 2, minWidth: 240, background: "rgba(255,255,255,0.02)",
          border: `1px solid ${BORDER}`, borderRadius: 10, padding: "12px 14px" }}>
          <div style={{ fontSize: 10, letterSpacing: "0.12em", textTransform: "uppercase",
            color: CYAN, fontWeight: 700, fontFamily: mono, marginBottom: 10 }}>Steps · goal {bm.steps.goal.toLocaleString()}/day</div>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: 10 }}>
            <div>
              <div style={{ fontSize: 9.5, color: FAINT, fontFamily: mono, marginBottom: 2 }}>CURRENT (today)</div>
              <div style={{ fontFamily: "Archivo, sans-serif", fontSize: 22, fontWeight: 700,
                color: stepsGoalColor(bm.steps.daily[bm.steps.daily.length - 1]?.steps || 0) }}>
                {(bm.steps.daily[bm.steps.daily.length - 1]?.steps || 0).toLocaleString()}
              </div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div style={{ fontSize: 9.5, color: FAINT, fontFamily: mono, marginBottom: 2 }}>WK AVG</div>
              <div style={{ fontFamily: "Archivo, sans-serif", fontSize: 22, fontWeight: 700,
                color: bm.steps.weekAvg >= bm.steps.goal ? GOOD : WATCH }}>
                {bm.steps.weekAvg.toLocaleString()}
              </div>
            </div>
          </div>
          <div style={{ display: "flex", gap: 4, alignItems: "flex-end", height: 44, marginBottom: 6 }}>
            {bm.steps.daily.map(d => {
              const pct = Math.min(d.steps / bm.steps.goal, 1);
              return (
                <div key={d.date} style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", gap: 2 }}>
                  <div style={{ width: "100%", height: `${Math.max(pct * 40, 3)}px`,
                    background: stepsGoalColor(d.steps), borderRadius: 3, opacity: 0.85 }} />
                  <span style={{ fontSize: 8.5, color: FAINT, fontFamily: mono }}>{d.date.split(" ")[1]}</span>
                </div>
              );
            })}
          </div>
        </div>

        {/* Vitals column */}
        <div style={{ flex: 1, minWidth: 160, background: "rgba(255,255,255,0.02)",
          border: `1px solid ${BORDER}`, borderRadius: 10, padding: "12px 14px" }}>
          <div style={{ fontSize: 10, letterSpacing: "0.12em", textTransform: "uppercase",
            color: CYAN, fontWeight: 700, fontFamily: mono, marginBottom: 10 }}>Vitals</div>
          <MetricPair label="Resting HR" current={bm.rhr.current} weekAvg={bm.rhr.weekAvg} unit=" bpm" currentColor={GOOD} />
          <MetricPair label="Systolic BP" current={bm.bloodPressure.current} weekAvg={bm.bloodPressure.weekAvg} unit=" mmHg" currentColor={WATCH} />
          <MetricPair label="Water intake" current={`${(bm.waterIntake.current / 1000).toFixed(2)}L`} weekAvg={`${(bm.waterIntake.weekAvg / 1000).toFixed(2)}L`} unit="" currentColor={bm.waterIntake.current >= 4000 ? GOOD : OFF} />
        </div>
      </div>
    </div>
  );
}

function ClientCard({ c, i }) {
  const [open, setOpen] = useState(c.scanned);
  const [hover, setHover] = useState(false);

  if (!c.scanned) {
    return (
      <div className="card-enter" style={{ animationDelay: `${i * 0.07}s`, background: PANEL,
        border: `1px dashed ${BORDER}`, borderRadius: 16, padding: "18px 22px", display: "flex",
        alignItems: "center", justifyContent: "space-between", backdropFilter: "blur(10px)" }}>
        <div style={{ fontFamily: "Archivo, sans-serif", fontWeight: 600, fontSize: 16, color: FAINT }}>{c.name}</div>
        <Pill tone="neutral">Awaiting scan</Pill>
      </div>
    );
  }

  const ups = c.progression.filter((p) => p.action === "up");
  const soon = c.progression.filter((p) => p.action === "soon");
  const nut = c.nutrition;
  const calDelta = nut.tracked ? nut.avgCal - nut.targetCal : 0;

  return (
    <div className="card-enter" onMouseEnter={() => setHover(true)} onMouseLeave={() => setHover(false)}
      style={{ animationDelay: `${i * 0.07}s`, background: open ? PANEL_HI : PANEL,
        border: `1px solid ${open || hover ? BORDER_HI : BORDER}`, borderRadius: 16, overflow: "hidden",
        backdropFilter: "blur(14px)", position: "relative",
        boxShadow: open ? `0 0 50px rgba(77,184,255,0.12)` : hover ? `0 0 26px rgba(77,184,255,0.08)` : "none",
        transition: "all 0.3s" }}>
      {open && <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 1, overflow: "hidden" }}>
        <div style={{ position: "absolute", width: "35%", height: 1,
          background: `linear-gradient(90deg,transparent,${CYAN},transparent)`,
          animation: "scanline 3.5s linear infinite" }} /></div>}

      <div onClick={() => setOpen(!open)} style={{ cursor: "pointer", padding: "18px 22px",
        display: "flex", alignItems: "center", gap: 14 }}>
        <div style={{ width: 7, height: 7, borderRadius: 100, background: open ? CYAN : FAINT,
          animation: open ? "pulseGlow 2s ease-in-out infinite" : "none", "--c": BLUE_GLOW, transition: "all 0.3s" }} />
        <div style={{ flex: 1 }}>
          <div style={{ fontFamily: "Archivo, sans-serif", fontWeight: 700, fontSize: 17, color: TEXT }}>{c.name}</div>
          <div style={{ fontSize: 11.5, color: DIM, marginTop: 2 }}>{c.phase}</div>
        </div>
        <div style={{ display: "flex", gap: 7, alignItems: "center" }}>
          <Pill tone={c.sessions.done === c.sessions.total ? "good" : "off"}>{c.sessions.done}/{c.sessions.total}</Pill>
          {ups.length > 0 && <Pill tone="blue" pulse>{ups.length} load ↑</Pill>}
          {nut.tracked
            ? <Pill tone={Math.abs(calDelta) > 300 ? "off" : "good"}>{calDelta > 0 ? "+" : ""}{calDelta}cal</Pill>
            : <Pill tone="watch">no food log</Pill>}
        </div>
        <div style={{ color: BLUE, fontSize: 16, transform: open ? "rotate(90deg)" : "none", transition: "transform 0.3s" }}>›</div>
      </div>

      {open && (
        <div style={{ padding: "4px 22px 24px" }}>
          <div style={{ display: "flex", gap: 22, flexWrap: "wrap", marginBottom: 26, paddingTop: 18,
            borderTop: `1px solid ${BORDER}` }}>
            <Stat label="Weight" value={`${c.weight.current}`} sub={`${c.weight.deltaKg > 0 ? "+" : ""}${c.weight.deltaKg}kg · 7d`}
              tone={c.weight.trend === "down" ? GOOD : c.weight.trend === "flat" ? WATCH : null} />
            <Stat label="Sessions" value={`${c.sessions.done}/${c.sessions.total}`}
              sub={c.sessions.missed ? `missed ${c.sessions.missed}` : c.sessions.cardio}
              tone={c.sessions.done < c.sessions.total ? OFF : null} />
            <Stat label="PBs" value={c.pbs} sub="this week" tone={c.pbs > 0 ? CYAN : null} />
            <Stat label="Check-in" value={c.checkin.submitted ? c.checkin.difficulty : "—"} sub={c.checkin.note} />
          </div>

          {c.flags && c.flags.length > 0 && (
            <div style={{ marginBottom: 26 }}>
              <SectionLabel>Flags</SectionLabel>
              {c.flags.map((f, k) => (
                <div key={k} style={{ fontSize: 12.5, color: OFF, padding: "4px 0",
                  display: "flex", gap: 8, alignItems: "baseline" }}>
                  <span>▸</span>{f}</div>
              ))}
            </div>
          )}

          {c.bodyMetrics && <BodyMetricsSection bm={c.bodyMetrics} />}

          <div style={{ marginBottom: 26 }}>
            <SectionLabel>Load increase · top of range, both sets ({ups.length})</SectionLabel>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "2px 18px" }}>
              {ups.map((p) => (
                <div key={p.ex} style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline",
                  padding: "6px 0", borderBottom: "1px solid rgba(120,180,255,0.08)" }}>
                  <span style={{ fontSize: 13, color: TEXT }}>{p.ex}</span>
                  <span style={{ fontSize: 11, color: BLUE, fontFamily: mono }}>{p.logged}</span>
                </div>
              ))}
            </div>
            {soon.length > 0 && (
              <div style={{ marginTop: 12, fontSize: 11.5, color: DIM }}>
                <span style={{ color: WATCH, fontFamily: mono, fontWeight: 600 }}>WATCH </span>
                {soon.map((p) => p.ex).join(", ")} — one more session.
              </div>
            )}
          </div>

          {c.nutritionSplit ? (
            <DayTypeNutrition split={c.nutritionSplit} />
          ) : (
          <div style={{ marginBottom: 26 }}>
            <SectionLabel>Nutrition vs target · 7d avg</SectionLabel>
            {nut.tracked ? (
              <div>
                <MacroBar label="Calories" actual={nut.avgCal} target={nut.targetCal} unit="cal" />
                <MacroBar label="Protein" actual={nut.protein[0]} target={nut.protein[1]} unit="g" />
                <MacroBar label="Carbs" actual={nut.carbs[0]} target={nut.carbs[1]} unit="g" />
                <MacroBar label="Fat" actual={nut.fat[0]} target={nut.fat[1]} unit="g" />
                {nut.note && <div style={{ marginTop: 12, fontSize: 11.5, color: WATCH,
                  border: "1px solid rgba(255,212,122,0.25)", background: "rgba(255,212,122,0.06)",
                  padding: "9px 12px", borderRadius: 9 }}>⚑ {nut.note}</div>}
              </div>
            ) : (
              <div>
                <div style={{ fontSize: 12.5, color: DIM, marginBottom: 10 }}>
                  Targets set — {nut.targetCal}cal · {nut.protein[1]}P / {nut.carbs[1]}C / {nut.fat[1]}F — but no meals logged this week.
                </div>
                {nut.note && <div style={{ fontSize: 11.5, color: WATCH,
                  border: "1px solid rgba(255,212,122,0.25)", background: "rgba(255,212,122,0.06)",
                  padding: "9px 12px", borderRadius: 9 }}>⚑ {nut.note}</div>}
              </div>
            )}
          </div>
          )}

          <div>
            <SectionLabel>Habits</SectionLabel>
            {c.habits.map((h) => (
              <div key={h.name} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "7px 0" }}>
                <span style={{ fontSize: 13, color: TEXT }}>{h.name}</span>
                <div style={{ display: "flex", gap: 9, alignItems: "center" }}>
                  {h.missed.length > 0 && <span style={{ fontSize: 11, color: OFF, fontFamily: mono }}>missed {h.missed.join(", ")}</span>}
                  <Pill tone={h.rate >= 85 ? "good" : h.rate >= 70 ? "watch" : "off"}>{h.rate}%</Pill>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

